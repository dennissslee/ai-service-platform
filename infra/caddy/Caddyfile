{$PORTAL_DOMAIN} {
	encode zstd gzip
	reverse_proxy portal:80
}

{$NEW_API_DOMAIN} {
	encode zstd gzip
	reverse_proxy new-api:3000
}

{$SUB2API_DOMAIN} {
	encode zstd gzip
	reverse_proxy sub2api:443 sub2api:8080 {
		lb_try_duration 5s
		lb_try_interval 250ms
	}
}

{$LITELLM_DOMAIN} {
	encode zstd gzip
	reverse_proxy litellm:4000
}

{$OPEN_WEBUI_DOMAIN} {
	encode zstd gzip
	reverse_proxy open-webui:8080
}
