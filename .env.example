# Global
TZ=Asia/Shanghai
COMPOSE_PROJECT_NAME=ai-platform

# Public domains
# Point these DNS records to your AWS server before starting Caddy with HTTPS.
PORTAL_DOMAIN=example.com
NEW_API_DOMAIN=new-api.example.com
SUB2API_DOMAIN=sub2api.example.com
LITELLM_DOMAIN=litellm.example.com
OPEN_WEBUI_DOMAIN=chat.example.com

# Optional local bind ports. Caddy is the intended public entrypoint.
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
PORTAL_PORT=8080
NEW_API_PORT=3000
SUB2API_PORT=3001
LITELLM_PORT=4000
OPEN_WEBUI_PORT=8081

# Images
PORTAL_IMAGE=caddy:2-alpine
NEW_API_IMAGE=calciumion/new-api:latest
SUB2API_IMAGE=weishaw/sub2api:latest
LITELLM_IMAGE=ghcr.io/berriai/litellm:main-latest
OPEN_WEBUI_IMAGE=ghcr.io/open-webui/open-webui:main
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine

# Databases
NEW_API_POSTGRES_DB=new_api
NEW_API_POSTGRES_USER=new_api
NEW_API_POSTGRES_PASSWORD=change-me-new-api-postgres-password

LITELLM_POSTGRES_DB=litellm
LITELLM_POSTGRES_USER=litellm
LITELLM_POSTGRES_PASSWORD=change-me-litellm-postgres-password

SUB2API_POSTGRES_DB=sub2api
SUB2API_POSTGRES_USER=sub2api
SUB2API_POSTGRES_PASSWORD=change-me-sub2api-postgres-password

# Redis
REDIS_PASSWORD=change-me-redis-password

# new-api
NEW_API_SQL_DSN=postgres://new_api:change-me-new-api-postgres-password@postgres-new-api:5432/new_api?sslmode=disable
NEW_API_REDIS_CONN_STRING=redis://:change-me-redis-password@redis:6379/0
NEW_API_SESSION_SECRET=change-me-new-api-session-secret
NEW_API_FRONTEND_BASE_URL=https://new-api.example.com

# sub2api
SUB2API_BASE_URL=https://sub2api.example.com
SUB2API_DATABASE_URL=postgres://sub2api:change-me-sub2api-postgres-password@postgres-sub2api:5432/sub2api?sslmode=disable
SUB2API_REDIS_URL=redis://:change-me-redis-password@redis:6379/1
SUB2API_GIN_MODE=release

# LiteLLM
LITELLM_MASTER_KEY=change-me-litellm-master-key
LITELLM_SALT_KEY=change-me-litellm-salt-key
LITELLM_DATABASE_URL=postgresql://litellm:change-me-litellm-postgres-password@postgres-litellm:5432/litellm
LITELLM_UI_USERNAME=admin
LITELLM_UI_PASSWORD=change-me-litellm-ui-password

# Open WebUI
OPEN_WEBUI_SECRET_KEY=change-me-open-webui-secret-key
OPEN_WEBUI_NAME=AI Chat
OPENAI_API_BASE_URL=https://litellm.example.com
OPENAI_API_BASE_URLS=https://litellm.example.com
OPENAI_API_KEY=change-me-litellm-master-key

# Caddy
CADDY_EMAIL=admin@example.com
